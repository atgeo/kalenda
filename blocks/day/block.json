{
  "apiVersion": 3,
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "name": "kalenda/day",
  "title": "Kalenda Day",
  "description": "Displays a single day from Kalenda.",
  "category": "kalenda",
  "textdomain": "kalenda",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "render": "file:./render.php",
  "attributes": {
    "type": {
      "type": "string",
      "default": "general"
    },
    "calendarId": {
      "type": "string",
      "default": ""
    },
    "locale": {
      "type": "string",
      "default": "en"
    },
    "date": {
      "type": "string",
      "default": ""
    },
    "title": {
      "type": "string",
      "default": ""
    },
    "showDate": {
      "type": "boolean",
      "default": true
    }
  }
}
